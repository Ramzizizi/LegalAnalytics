# DEBUG=False — режим продакшна (по умолчанию). True — только для локальной разработки.
DEBUG=False

# SECRET_KEY обязателен при DEBUG=False (иначе приложение не стартует).
# Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

ALLOWED_HOSTS=localhost,127.0.0.1

# БД: sqlite (локально) или postgresql (prod/docker)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@db:5432/legal_docs

POSTGRES_DB=legal_docs
POSTGRES_USER=legal_user
POSTGRES_PASSWORD=legal_password
